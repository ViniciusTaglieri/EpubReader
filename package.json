{
  "name": "epub-reader",
  "version": "0.1.0",
  "private": true,
  "description": "Local desktop EPUB reader built with Tauri, Rust, React, TypeScript, SQLite and Tailwind CSS.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "check": "npm run quality && npm run test && npm run build",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "eslint . && biome lint .",
    "quality": "npm run format:check && npm run lint",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "tauri": "tauri",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@vitejs/plugin-react": "^6.0.1",
    "epubjs": "^0.3.93",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "overrides": {
    "epubjs": {
      "@xmldom/xmldom": "0.9.10"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@eslint/js": "10.0.1",
    "@tauri-apps/cli": "^2.11.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.23",
    "eslint": "10.3.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.6.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "typescript": "^6.0.3",
    "typescript-eslint": "8.59.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
